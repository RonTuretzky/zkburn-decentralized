# Deployed ZKBurn V2 contract on Gnosis Chain
NEXT_PUBLIC_ZKBURN_ADDRESS=0xE8bE1A3C20a484c66668c500E6306968f92ceb88

# Gnosis RPC. Prefer a CORS-friendly endpoint for the browser
# (e.g. https://gnosis-rpc.publicnode.com). Default: https://rpc.gnosischain.com
NEXT_PUBLIC_RPC_URL=

# Must match the ZKBURN_DOMAIN the contract was deployed with (default: zkburn.app)
NEXT_PUBLIC_ZKBURN_DOMAIN=

# DEV ONLY. "1" shows a "Simulate proof (dev only)" button that fabricates a
# well-formed proof so the full flow can be exercised without the ZKPassport app.
# Leave unset in production — the real zkPassport QR is the only registration path.
NEXT_PUBLIC_DEMO_MODE=

# zkPassport devMode (mock ZKR passports allowed); "false" to disable
NEXT_PUBLIC_ZKPASSPORT_DEVMODE=
